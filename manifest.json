{
  "manifest_version": 3,
  "name": "Aid",
  "version": "0.1.0",
  "description": "Cross-browser extension that docks a ChatGPT-style side panel with interchangeable LLM backends",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://*.googleapis.com/*",
    "https://openrouter.ai/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "action": {
    "default_title": "Toggle Aid",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'; connect-src 'self' https://api.openai.com https://api.anthropic.com https://*.googleapis.com https://openrouter.ai http://localhost:* http://127.0.0.1:*; style-src 'self' 'unsafe-inline'; object-src 'none';"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/fonts/*.woff2"],
      "matches": ["<all_urls>"]
    }
  ]
}
